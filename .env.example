# Local development environment variables.
# Copy this file to `.env` and adjust values as needed. `.env` is gitignored.

# ── Postgres (deploy/docker-compose.dev.yml) ─────────────────────────────────
POSTGRES_USER=fl_web
POSTGRES_PASSWORD=fl_web
POSTGRES_DB=fl_web

# Connection string used by the backend when it runs on the host (not in a
# container) and talks to the Postgres container published on localhost:5432.
DATABASE_URL=postgresql+psycopg://fl_web:fl_web@localhost:5432/fl_web
